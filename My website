}

/* SECTION */

.section{
padding:90px 10%;
}

.title{
text-align:center;
font-size:40px;
margin-bottom:60px;
color:#ff3c00;
}

/* ABOUT */

.about{
display:grid;
grid-template-columns:1fr 1fr;
gap:50px;
align-items:center;
}

.about img{
width:100%;
border-radius:10px;
}

/* SERVICES */

.services{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:30px;
}

.service{
background:#161616;
padding:35px;
border-radius:10px;
transition:.3s;
border:1px solid #222;
text-align:center;
}

.service:hover{
transform:translateY(-10px);
border-color:#ff3c00;
}

.service h3{
margin-bottom:10px;
color:#ff3c00;
}

/* STATS */

.stats{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:30px;
text-align:center;
}

.stat{
background:#151515;
padding:30px;
border-radius:8px;
}

.stat h2{
color:#ff3c00;
font-size:40px;
}

/* TESTIMONIALS */

.testimonials{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
gap:30px;
}

.testimonial{
background:#151515;
padding:30px;
border-radius:8px;
font-style:italic;
}

/* FORM */

form{
max-width:600px;
margin:auto;
}

input,textarea{
width:100%;
padding:14px;
margin-bottom:15px;
border:none;
background:#1a1a1a;
color:white;
border-radius:5px;
}

button{
width:100%;
padding:15px;
background:#ff3c00;
border:none;
color:white;
font-weight:600;
cursor:pointer;
border-radius:5px;
}

/* WHATSAPP BUTTON */

.whatsapp{
position:fixed;
bottom:25px;
right:25px;
background:#25D366;
color:white;
padding:15px 18px;
border-radius:50%;
font-size:22px;
text-decoration:none;
}

/* FOOTER */

footer{
background:black;
padding:30px;
text-align:center;
margin-top:60px;
color:#aaa;
}

/* MOBILE */

@media(max-width:800px){

.hero h1{
font-size:38px;
}

.about{
grid-template-columns:1fr;
}

}

</style>

